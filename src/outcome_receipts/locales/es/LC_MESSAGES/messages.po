msgid "trace_provenance_pass_template"
msgstr "Ningún dato fue redactado por un modelo de lenguaje. La verificación de fundamentación se aprobó: {bound} número(s) del informe se vincularon con un recibo y {unbound} no se vincularon."

msgid "trace_provenance_fail_template"
msgstr "Ningún dato fue redactado por un modelo de lenguaje. La verificación de fundamentación no se aprobó: {bound} número(s) del informe se vincularon con un recibo y {unbound} no se vincularon."
